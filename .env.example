# Copy to `.env` to enable "app-triggered" enqueue to UiPath Orchestrator.
# When these are unset, ticket creation still works — enqueue is just skipped.
#
# Create an External Application in UiPath Automation Cloud (Admin → External
# Applications), Application Type = Confidential, with scope OR.Queues (and the
# folder that holds the queue). Use its Client ID / Secret below.

ORCH_CLOUD_URL=https://cloud.uipath.com
ORCH_ORG=gifsonmate
ORCH_TENANT=DefaultTenant
ORCH_CLIENT_ID=your-external-app-client-id
ORCH_CLIENT_SECRET=your-external-app-client-secret
ORCH_SCOPE=OR.Queues
# Orchestrator folder (Organization Unit) — MUST be the NUMERIC folder id
# (e.g. 4523203), NOT the folder GUID. Used as the X-UIPATH-OrganizationUnitId
# header; a GUID yields errorCode 1101 "A folder is required".
ORCH_FOLDER_ID=your-numeric-folder-id
ORCH_QUEUE_NAME=HelixNewTickets

# --- Backend-driven process orchestration (StartJobs) ---
# Broader OR scope to start jobs + read releases (must be granted on the app).
ORCH_PROC_SCOPE=OR.Default
# Process (release) names published in the folder:
ORCH_PROC_INSERT=Helix.DataFabricInsert
ORCH_PROC_ASSIGN=Helix.AssignByDepartment
ORCH_PROC_UPDATE=Helix.DataFabricUpdate
# Optional: pin release keys to skip the Releases lookup (needs Releases.Read).
# These equal the process keys shown in Orchestrator:
ORCH_RELEASE_INSERT=17A9745F-0209-4204-A4C9-62FF6395E8DE
ORCH_RELEASE_ASSIGN=960EBE1A-4AD9-422B-BF46-1496A7E57347
ORCH_RELEASE_UPDATE=F78C7B16-7C26-4130-AE03-7D549C8EBA18

# --- Maestro orchestration (backend starts it; Maestro owns the ticket flow) ---
# Release key of the deployed Helix_TicketOrchestration (CHANGES on every
# solution re-deploy — read it from `uip maestro bpmn process list`).
ORCH_MAESTRO_RELEASE=acf6c9f3-dba9-4ada-9d8b-a54598cd67da
# NUMERIC folder id of the orchestration's solution folder (HelixSolutionOrch).
ORCH_MAESTRO_FOLDER_ID=8069911

# ---- Power Apps Dataverse (PRIMARY source for CRM accounts & contacts) ----
# When set, the /api/accounts and /api/contacts routes serve live records from
# Dataverse and fall back to seeded SQLite on any error. When unset, SQLite is
# used directly. Create an Azure AD app registration with a client secret and
# grant it the Dataverse app user + a security role in Power Platform admin.
DATAVERSE_TENANT_ID=your-azure-ad-tenant-id
DATAVERSE_CLIENT_ID=your-app-registration-client-id
DATAVERSE_CLIENT_SECRET=your-app-registration-client-secret
DATAVERSE_BASE_URL=https://orgxxxxxxxx.crm4.dynamics.com
DATAVERSE_API_VERSION=v9.2

# ---- Firebase social sign-in (hybrid bridge) ----
# Your Firebase project id. When set, POST /api/auth/firebase verifies Firebase
# ID tokens (Google/phone/email-link) against Google public keys and issues an
# app JWT. Leave blank to disable social sign-in (email+password still works).
FIREBASE_PROJECT_ID=your-firebase-project-id

# ---- Knowledge assistant (Supabase vector store + OpenAI RAG) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional: use anon key if the RPC or table are published publicly.
SUPABASE_ANON_KEY=your-supabase-anon-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ---- Voice input (speech-to-text) ----
# PRIMARY: self-hosted Whisper in the Python service (no billing, no Google
# dependency). The Node backend proxies audio to <STT_SERVICE_URL>/transcribe.
# Defaults to TTS_SERVICE_URL (same Python service), else http://127.0.0.1:8081.
# STT_SERVICE_URL=http://127.0.0.1:8081
# STT_SERVICE_TIMEOUT_MS=90000   # generous: CPU inference + first-run model load
# Whisper model/runtime are set on the PYTHON service (see tts-service): WHISPER_MODEL, WHISPER_DEVICE, WHISPER_COMPUTE_TYPE.
#
# FALLBACK: OpenAI transcription, used only if the self-hosted service can't
# transcribe AND this key has quota. whisper-1 is reliable; gpt-4o-transcribe also works.
OPENAI_STT_MODEL=whisper-1

# ---- Native-language translation (Igbo/Yorùbá/Hausa <-> English) ----
# The assistant translates a native question to English for knowledge-base
# retrieval, then translates the answer back to the selected language. Runs in
# the Python service (deep_translator/Google Translate, no API key). Defaults to
# STT_SERVICE_URL / TTS_SERVICE_URL (same Python service).
# TRANSLATE_SERVICE_URL=http://127.0.0.1:8081
# TRANSLATE_TIMEOUT_MS=8000

# ---- Initial super admin (RBAC root, seeded on first boot) ----
# Defaults to superadmin@gifsonservices.onmicrosoft.com / super1234 if unset. Override for real deploys.
SUPERADMIN_EMAIL=superadmin@gifsonservices.onmicrosoft.com
SUPERADMIN_PASSWORD=super1234

# ---- Organizational email domain for seeded accounts ----
# Rebrand the seeded logins from gifsonservices.onmicrosoft.com to your own domain. When set,
# accounts become demo@<domain>, admin@<domain>, superadmin@<domain>.
# Per-account full overrides also available (DEMO_EMAIL/ADMIN_EMAIL/SUPERADMIN_EMAIL).
ORG_EMAIL_DOMAIN=gifsonservices.onmicrosoft.com
# DEMO_EMAIL=demo@yourbank.com
# ADMIN_EMAIL=admin@yourbank.com

# ---- SLA escalation (auto-reassign high-priority; email admin when stuck) ----
# High-priority (high/urgent) requests left untreated past ESCALATION_MINUTES are
# auto-reassigned to the next agent in their department (round-robin). When there
# is no available assignee (empty department, or none chosen at intake), an
# escalation email is sent to the admin (always an admin@… address).
# ESCALATION_MINUTES=2
# ESCALATION_CHECK_SECONDS=30
# ESCALATION_PRIORITIES=high,urgent
# SMTP (leave unset to disable email — reassignment still works, sends are logged):
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notifications@yourbank.com
# SMTP_PASS=__app_password__
# SMTP_FROM=notifications@yourbank.com
# Escalation recipient — must start with admin@ (else derived as admin@<ORG_EMAIL_DOMAIN>):
# ADMIN_EMAIL=admin@yourbank.com

# ---- KYC face verification provider (server-side, authoritative) ----
# Unset = disabled (client verifies on-device). Options: smileid | dojah | mock.
# 'dojah' uses the Dojah credentials below (photo-ID selfie match); 'smileid' is
# still a placeholder in src/kyc.ts; 'mock' always passes (test only).
# KYC_PROVIDER=dojah

# ---- Dojah — real BVN / NIN / document verification (NIGERIA) ----
# When set, BVN is checked against NIBSS, NIN against NIMC, and uploaded ID
# documents are analysed by Dojah. When unset, those fall back to a local
# format/heuristic check (not authoritative) so development still works.
# Get keys at https://dojah.io (dashboard → API keys).
# DOJAH_APP_ID=your-dojah-app-id
# DOJAH_API_KEY=your-dojah-secret-key
# DOJAH_BASE_URL=https://api.dojah.io   # or the sandbox base URL
# KYC_TIMEOUT_MS=12000

# ---- Owning organization (branding + request routing by email domain) ----
# Seeded on first boot; also manageable live in Admin -> Organization.
ORG_NAME=GifsonServices
ORG_DOMAIN=gifsonservices.com

# Shared secret Maestro sends as X-UIPATH-SYNC-KEY to the /api/maestro/ticket-sync callback.
MAESTRO_SYNC_KEY=change-me-shared-secret

# ---- Text-to-speech (Python engine) ----
# The /assistant/tts route proxies to the Python TTS service (see tts-service/).
# Speech is NOT synthesized in Node. Point this at the running engine; leave the
# default for a local sidecar. If unset/unreachable, the client falls back to
# browser speech synthesis.
TTS_SERVICE_URL=http://127.0.0.1:8081
# Request timeout (ms) for the proxy call.
# TTS_TIMEOUT_MS=15000
